# Stellar RPC + Horizon (public endpoints, fine to ship in the bundle)
VITE_STELLAR_RPC_TESTNET=https://soroban-testnet.stellar.org
VITE_STELLAR_RPC_MAINNET=https://mainnet.sorobanrpc.com
VITE_HORIZON_TESTNET=https://horizon-testnet.stellar.org
VITE_HORIZON_MAINNET=https://horizon.stellar.org

# analytics backend
VITE_ANALYTICS_API_URL=http://localhost:8085

# WalletConnect project id from cloud.reown.com. Public (rate-limit key,
# not a secret). Leave empty to skip WC: LOBSTR desktop and injected EVM
# wallets (MetaMask, Rabby) still work. Required for LOBSTR mobile and
# WalletConnect-based EVM wallets.
VITE_WALLETCONNECT_PROJECT_ID=

# EVM RPC overrides (defaults fall back to ankr public endpoints).
# Set these if you hit rate limits or want a dedicated provider.
VITE_ETH_RPC=
VITE_ARB_RPC=
VITE_BSC_RPC=

# testnet | mainnet
VITE_DEFAULT_NETWORK=testnet
