# Stellar RPC + Horizon (public endpoints, fine to ship in the bundle)
VITE_STELLAR_RPC_TESTNET=https://soroban-testnet.stellar.org
VITE_STELLAR_RPC_MAINNET=https://mainnet.sorobanrpc.com
VITE_HORIZON_TESTNET=https://horizon-testnet.stellar.org
VITE_HORIZON_MAINNET=https://horizon.stellar.org

# WalletConnect project id from cloud.reown.com. Public (rate-limit key,
# not a secret). Leave empty to skip WC: LOBSTR desktop and injected EVM
# wallets (MetaMask, Rabby) still work. Required for LOBSTR mobile and
# WalletConnect-based EVM wallets.
VITE_WALLETCONNECT_PROJECT_ID=

# EVM RPC overrides (defaults fall back to ankr public endpoints).
# Set these if you hit rate limits or want a dedicated provider.
VITE_ETH_RPC=
VITE_ARB_RPC=
VITE_BSC_RPC=

# testnet | mainnet
VITE_DEFAULT_NETWORK=testnet

# Stellar Broker partner key. Public bundle-safe (rate-limited per key
# server-side, like a Mapbox key). Apply at stellar.broker/request-access.
# Empty disables the best-execution path; swaps fall back to direct DEX.
VITE_STELLAR_BROKER_PARTNER_KEY=

# DFNS MPC custody. Server-side only (Hono process). No VITE_ prefix
# on any of these - the private key in particular must never reach the bundle.
# API base is https://api.dfns.io (the trial signup at app.dfns.io covers
# testnet wallets from the same host). Grab the exact value the console shows.
DFNS_API_URL=https://api.dfns.io
# APP_ID is recorded for the console only; the keysigner client authenticates
# with AUTH_TOKEN + CRED_ID + the private key and never sends APP_ID.
DFNS_APP_ID=
DFNS_AUTH_TOKEN=
DFNS_CRED_ID=
# you generate this keypair yourself: register the public key on the service
# account, keep the private key here. ed25519 (the keysigner signs with no
# explicit digest, which only ed25519 keys support).
# local dev reads it from a file path. cloud (Render/Fly) has no file to mount,
# so paste the PEM content into DFNS_PRIVATE_KEY instead and leave the path
# empty; the env form wins when both are set.
DFNS_PRIVATE_KEY_PATH=_local/dfns/service-account.pem
DFNS_PRIVATE_KEY=
DFNS_WEBHOOK_SECRET=
# DFNS wallet that signs Stellar transactions. Network value is
# 'Stellar' for pubnet, 'StellarTestnet' for testnet.
DFNS_STELLAR_NETWORK=StellarTestnet
DFNS_STELLAR_WALLET_ID=

# Treasury G-address whose key DFNS holds. Every /dfns/sign envelope must
# source from this account, otherwise the request is rejected 400. Required
# in production; without it the endpoint stays 503-closed.
DFNS_TREASURY_ADDRESS=

# Comma-separated G-addresses any Payment / PathPayment may target. Empty
# disables destination whitelisting (testing path). Production should fill.
DFNS_DESTINATION_WHITELIST=

# Hard cap on any payment-style op, expressed in stroops (1 XLM = 10000000).
# 0 disables the cap (testing path). Production should set a positive value.
DFNS_MAX_AMOUNT_STROOPS=0

# CORS origin that the Hono SSE endpoint trusts. Must match the dashboard
# origin exactly; wildcards are illegal with credentials.
DASHBOARD_ORIGIN=http://localhost:5173

# Shared token that gates /dfns/wallets, /dfns/policies and /sse. Empty in
# local dev leaves them open; in prod set a long random value and mirror it
# into VITE_LOBSTER_API_TOKEN below. The client copy is bundled, so treat it
# as a scraping gate, not a real secret; front the service with auth for more.
LOBSTER_API_TOKEN=

# Browser base url for the Hono webhook + sse + policies service. Set to
# the deployed Fly/Render url in prod. /sse and /dfns/policies hang off it.
VITE_LOBSTER_API_URL=http://localhost:8787

# Must equal LOBSTER_API_TOKEN above when that is set. Sent as a header on
# /dfns reads and as a ?token= query on the EventSource feed.
VITE_LOBSTER_API_TOKEN=

# LEI of the Lobster CASP entity. Stamped into every MiCA record exported
# via /dfns/audit/export. Leave empty in dev, fill before any real export.
LOBSTER_CASP_LEI=

# Hono webhook + sse port. Defaults to 8787 when unset.
PORT=8787

# --- TTL monitor daemon (server-side, no VITE_ prefix) ---
# Which network the daemon watches and how often. Falls back to the public
# Soroban endpoint when the override is empty.
TTL_MONITOR_NETWORK=testnet
SOROBAN_RPC_TESTNET=https://soroban-testnet.stellar.org
SOROBAN_RPC_MAINNET=https://mainnet.sorobanrpc.com
TTL_MONITOR_INTERVAL_MS=300000
# 1 runs the ttl loop inside the web service process, for hosts that bill
# per process. default is the standalone daemon (npm run ttl-monitor).
TTL_MONITOR_EMBEDDED=

# Prometheus Pushgateway the daemon writes its gauges to. Empty disables push.
PUSHGATEWAY_URL=

# --- Service probe daemon (server-side, shares PUSHGATEWAY_URL above) ---
# Liveness + balance probes grouped by deliverable. Frontend defaults to the
# production dashboard; override for a preview deploy. The testnet wallet is the
# D4 signer whose XLM the treasury board tracks. The treasury account and DFNS
# API come from DFNS_TREASURY_ADDRESS / DFNS_API_URL above; a probe is skipped
# when its address or url is empty.
MONITOR_FRONTEND_URL=
MONITOR_TESTNET_WALLET=
# only probed when set to a non-localhost url
MONITOR_BFF_URL=
# funded mainnet account the synthetic Soroswap quote reads from. Falls back to
# DFNS_TREASURY_ADDRESS; the pair check is skipped when neither is set.
MONITOR_SOROSWAP_SOURCE=
