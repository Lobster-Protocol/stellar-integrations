# Stellar RPC endpoints
VITE_STELLAR_RPC_TESTNET=https://soroban-testnet.stellar.org
VITE_STELLAR_RPC_MAINNET=https://mainnet.sorobanrpc.com

# Lobster analytics API (DataProcess service)
VITE_ANALYTICS_API_URL=http://localhost:8085

# WalletConnect project ID (for LOBSTR integration)
# Get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Default network (testnet | mainnet)
VITE_DEFAULT_NETWORK=testnet
