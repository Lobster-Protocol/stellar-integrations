# ─────────────────────────────────────────────────────────────────────────
# Stellar RPC endpoints (public, safe to expose in client bundle)
# ─────────────────────────────────────────────────────────────────────────
VITE_STELLAR_RPC_TESTNET=https://soroban-testnet.stellar.org
VITE_STELLAR_RPC_MAINNET=https://mainnet.sorobanrpc.com

# ─────────────────────────────────────────────────────────────────────────
# Lobster analytics API (DataProcess service)
# ─────────────────────────────────────────────────────────────────────────
VITE_ANALYTICS_API_URL=http://localhost:8085

# ─────────────────────────────────────────────────────────────────────────
# WalletConnect project ID (LOBSTR mobile + multi-wallet via QR)
# ─────────────────────────────────────────────────────────────────────────
# 1. Go to https://cloud.reown.com (ex-WalletConnect Cloud)
# 2. Create a project (name: "Lobster Protocol")
# 3. Copy the Project ID here
#
# Public by design — bundled into the client JS. WalletConnect uses it as a
# rate-limit key, NOT a secret. Leave empty to skip registering the module
# (LOBSTR desktop extension still works via LobstrModule).
VITE_WALLETCONNECT_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────────
# Default network at app boot (testnet | mainnet)
# ─────────────────────────────────────────────────────────────────────────
VITE_DEFAULT_NETWORK=testnet
