# Local-only working material, never pushed.
# Convention: a folder named _local/ anywhere in the tree is local-only.
# Drop notes, scratch docs, anything per-area there and it stays off GitHub.
_local/
**/_local/
_docs/
notes/
docs/*.md
docs/*.json
scripts/*-evidence.mjs
scripts/*-ground-truth.mjs
scripts/deploy-*.mjs
NOTES.md
CHANGELOG.md
CLAUDE.md
.claude/
AGENTS.md
.cursor/
.cursorrules
.github/copilot-instructions.md
.aider*
.continue/
.windsurf/

# build artefacts not worth committing
.vercel/
coverage/
playwright-report/
*.tsbuildinfo

# local-only one-shot walkthrough (not a real assertion test)
tests/demo-walkthrough.spec.ts

# boilerplate meta-docs kept local
CODE_OF_CONDUCT.md
CONTRIBUTING.md
SECURITY.md
ARCHITECTURE.md
ENV.md
GOVERNANCE.md
SUPPORT.md
.github/ISSUE_TEMPLATE/
.github/PULL_REQUEST_TEMPLATE.md
.github/PULL_REQUEST_TEMPLATE/
.github/CODEOWNERS

